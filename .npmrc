auto-install-peers=false
strict-peer-dependencies=false

# Hoist Expo / React Native transitive deps to the workspace root node_modules
# so Metro can resolve them in pnpm strict mode. Without this, every
# transitive dep (expo-modules-core, @babel/runtime helpers, etc.) needs to
# be installed by hand.
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=react-native*
public-hoist-pattern[]=metro*
public-hoist-pattern[]=@react-navigation/*
public-hoist-pattern[]=whatwg-*
